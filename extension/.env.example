# Analytics endpoint — the landing site's Next.js API route that records opt-in,
# anonymous usage events. Copy this file to `.env` and set the deployed URL.
#
# Example: https://your-domain.com/api/events
#
# If left unset, analytics are a silent no-op — the extension works exactly as
# before. Analytics also never fire unless the user opts in via Settings.

VITE_ANALYTICS_ENDPOINT=

# Billing server origin (server-mode + Polar entitlements / paywall). Leave EMPTY
# to ship a pure-BYOK build with NO paywall (original behavior). Set it to enable
# payments + credits. Dev default: http://localhost:8787
VITE_BILLING_SERVER_URL=

# Marketing pricing page the in-panel paywall links to ("View plans"). Defaults to
# https://interviewary.dotportion.com/pricing. For local dev: http://localhost:3000/pricing
VITE_PRICING_URL=

# Build edition: 'lifetime' (BYOK + credits) or 'subscription' (credits only, no BYOK).
# The package script builds BOTH automatically; this is only for one-off manual builds.
# Defaults to 'lifetime'.
VITE_EDITION=lifetime
