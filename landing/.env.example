# Supabase — server-side only (used by the Next.js API routes /api/leads and /api/events).
# Copy this file to `.env.local` for local dev, and set the same vars in Netlify.
# See ../supabase/README.md for where to find these.
#
# These are SERVER secrets — they are never sent to the browser or the extension.
# Use the service_role key (NOT the anon key). Never prefix these with NEXT_PUBLIC_.
#
# If left unset, the site still works: the download proceeds without recording a
# lead, and analytics inserts are skipped.

SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
