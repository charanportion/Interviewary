{
  "name": "interview-copilot",
  "version": "0.0.1",
  "private": true,
  "description": "Chrome extension copilot for technical interviews — 2-week prototype",
  "scripts": {
    "dev": "pnpm --filter @interview-copilot/extension dev",
    "dev:extension": "pnpm --filter @interview-copilot/extension dev",
    "dev:landing": "pnpm --filter @interview-copilot/landing dev",
    "package:extension": "node landing/scripts/package-extension.mjs",
    "build": "pnpm -r build",
    "typecheck": "pnpm -r typecheck"
  },
  "engines": {
    "node": ">=22",
    "pnpm": ">=9"
  },
  "packageManager": "pnpm@9.12.0"
}
