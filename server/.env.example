# ───────── Billing server configuration ─────────
# Copy to .env and fill in. Use Polar SANDBOX values for development.

# HTTP
PORT=8787
# Comma-separated allowed origins for CORS. The extension's origin is
# chrome-extension://<id>. Use * in dev (auth is by bearer token anyway).
ALLOWED_ORIGINS=*

# ── Supabase Postgres ──
# Supabase Dashboard → Project Settings → Database → Connection string.
# Use the transaction pooler (port 6543) for a deployed server; the code sets
# prepare:false + ssl:require so either pooler mode works.
DATABASE_URL=postgresql://postgres.<ref>:<password>@aws-0-<region>.pooler.supabase.com:6543/postgres

# ── Auth (session tokens we issue to the extension) ──
JWT_SECRET=change-me-to-a-long-random-string
SESSION_TOKEN_TTL_SEC=3600

# ── Polar (Merchant of Record) ──
# 'sandbox' for dev, 'production' for live.
POLAR_SERVER=sandbox
POLAR_ACCESS_TOKEN=polar_oat_xxx
POLAR_ORGANIZATION_ID=00000000-0000-0000-0000-000000000000
POLAR_WEBHOOK_SECRET=whsec_xxx
# Product ids — filled automatically by `pnpm --filter ...server polar:setup`.
# Subscriptions (recurring) + lifetime (one-time) grant the app entitlement;
# top-ups only add credits.
POLAR_PRODUCT_SUB_STARTER=
POLAR_PRODUCT_SUB_PRO=
POLAR_PRODUCT_SUB_TEAM=
POLAR_PRODUCT_LIFE_STARTER=
POLAR_PRODUCT_LIFE_PRO=
POLAR_PRODUCT_TOPUP_SMALL=
POLAR_PRODUCT_TOPUP_MEDIUM=
POLAR_PRODUCT_TOPUP_LARGE=
# The usage meter that tracks interview minutes (its event name + id).
POLAR_METER_ID=
POLAR_EVENT_NAME=interview_minute
# Where Polar redirects after a successful checkout — MUST be a route the landing
# site actually serves (/checkout/success). Dev: http://localhost:3000/checkout/success.
# Prod: https://<your-landing-domain>/checkout/success (deploy the landing first!).
POLAR_SUCCESS_URL=http://localhost:3000/checkout/success

# ── Deepgram (server mode hands this single key to the extension) ──
DEEPGRAM_API_KEY=

# ── Server-mode LLM: Anthropic (Claude). The proxy forwards to this upstream. ──
ANTHROPIC_API_KEY=
ANTHROPIC_BASE_URL=https://api.anthropic.com/v1
ANTHROPIC_VERSION=2023-06-01
SERVER_MODEL_FAST=claude-haiku-4-5
SERVER_MODEL_REPORT=claude-sonnet-4-6
